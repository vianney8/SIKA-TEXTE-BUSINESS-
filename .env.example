# ─── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Sessions ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_random_string

# ─── Bot Telegram ─────────────────────────────────────────────────────────────
# Obtenir via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── SolvexPay (passerelle de paiement principale) ────────────────────────────
SOLVEXPAY_API_KEY=your_solvexpay_api_key
SOLVEXPAY_SECRET_KEY=your_solvexpay_secret_key
SOLVEXPAY_WEBHOOK_SECRET=your_solvexpay_webhook_secret

# ─── Object Storage (Replit) — pour vidéos et captures ───────────────────────
# Créer un bucket dans l'outil "Object Storage" de Replit
PRIVATE_OBJECT_DIR=/nom-du-bucket
PUBLIC_OBJECT_SEARCH_PATHS=/nom-du-bucket

# ─── Autres passerelles (optionnel) ───────────────────────────────────────────
SENDAVAPAY_API_KEY=
SENDAVAPAY_WEBHOOK_SECRET=
BKAPAY_PUBLIC_KEY=
BKAPAY_SIGNATURE_SECRET=
LYGOS_API_KEY=
LEEKPAY_SECRET_KEY=
LEEKPAY_PUBLIC_KEY=
